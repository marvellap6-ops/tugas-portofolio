# ==========================================================
# Salin file ini menjadi ".env" lalu isi dengan nilai asli.
# JANGAN commit file ".env" ke Git.
# ==========================================================

# --- Flask ---
SECRET_KEY=ganti-dengan-random-string-yang-panjang-dan-acak
FLASK_DEBUG=True

# --- TiDB Cloud (MySQL-compatible) ---
# Didapat dari dashboard TiDB Cloud > Connect
DB_HOST=gateway01.ap-southeast-1.prod.aws.tidbcloud.com
DB_PORT=4000
DB_USER=xxxxxxxx.root
DB_PASSWORD=isi-password-tidb
DB_NAME=portofolio_db
DB_SSL_ENABLED=True

# --- Cloudinary (penyimpanan gambar) ---
# Didapat dari dashboard Cloudinary > Settings > Access Keys
CLOUDINARY_CLOUD_NAME=isi-cloud-name
CLOUDINARY_API_KEY=isi-api-key
CLOUDINARY_API_SECRET=isi-api-secret

# --- Resend (pengiriman email) ---
# Didapat dari dashboard Resend > API Keys
RESEND_API_KEY=isi-resend-api-key
# Email pengirim harus dari domain yang sudah diverifikasi di Resend
# (atau pakai onboarding@resend.dev untuk uji coba)
RESEND_FROM_EMAIL=Portfolio <onboarding@resend.dev>
# Email tujuan saat ada pesan kontak baru dari pengunjung
CONTACT_RECEIVER_EMAIL=email-anda@example.com

# --- Admin default (dibuat otomatis oleh `python seed.py`) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ganti-password-ini
